--- a/Dockerfile
+++ b/Dockerfile
@@ -167,3 +167,3 @@ RUN curl --insecure --location --remote-name-all --remote-header-name \
 FROM dl-cross AS cross
-ARG ARCH=x86_64-w64-mingw32
+ARG ARCH=i686-w64-mingw32
 ENV ARCH=$ARCH
@@ -198,2 +198,3 @@ RUN echo '#include <crtdefs.h>' \
         --with-default-msvcrt=msvcrt-os \
+        --with-default-win32-winnt=0x0501 \
  && make -j$(nproc) \
@@ -232,2 +233,3 @@ COPY src/gcc-*.patch $PREFIX/src/
 RUN cat $PREFIX/src/gcc-*.patch | patch -d/dl/gcc -p1 \
+ && echo >/dl/gcc/gcc/config/i386/winnt-utf8.manifest \
  && /dl/gcc/configure \
@@ -235,2 +237,3 @@ COPY src/gcc-*.patch $PREFIX/src/
         --with-sysroot=/bootstrap \
+        --with-arch=pentium4 \
         --target=$ARCH \
@@ -250,4 +252,4 @@ RUN /dl/mingw/mingw-w64-crt/configure \
         --disable-dependency-tracking \
-        --disable-lib32 \
-        --enable-lib64 \
+        --enable-lib32 \
+        --disable-lib64 \
         CFLAGS="-O2" \
@@ -336,2 +338,3 @@ RUN /dl/mingw/mingw-w64-headers/configure \
         --with-default-msvcrt=msvcrt-os \
+        --with-default-win32-winnt=0x0501 \
  && make -j$(nproc) \
@@ -346,4 +349,4 @@ RUN /dl/mingw/mingw-w64-crt/configure \
         --disable-dependency-tracking \
-        --disable-lib32 \
-        --enable-lib64 \
+        --enable-lib32 \
+        --disable-lib64 \
         CFLAGS="-O2" \
@@ -374,2 +377,3 @@ RUN echo 'BEGIN {print "pecoff"}' \
         --with-native-system-header-dir=/include \
+        --with-arch=pentium4 \
         --target=$ARCH \
@@ -528,3 +533,3 @@ COPY src/busybox-* $PREFIX/src/
 RUN cat $PREFIX/src/busybox-*.patch | patch -p1 \
- && make mingw64u_defconfig \
+ && make mingw64_defconfig \
  && sed -ri 's/^(CONFIG_AR)=y/\1=n/' .config \
@@ -721,3 +729,4 @@ RUN cat $PREFIX/src/cmake-*.patch | patch -d/dl/cmake -p1 \
         -DCMAKE_EXE_LINKER_FLAGS="-s" \
+        -DCMAKE_CXX_FLAGS="-O2 -D_WIN32_WINNT=0x0601" \
         -DCMAKE_INSTALL_PREFIX=$PREFIX \
         -DBUILD_CursesDialog=ON \
