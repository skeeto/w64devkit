Universal Ctags incorrectly rejects paths with trailing spaces

--- a/main/routines.c
+++ b/main/routines.c
@@ -440,2 +440,24 @@ extern void setCurrentDirectory (void) /* TODO */
 
+#ifdef _WIN32
+static char *trimTrailingDirectorySeparatorsNew (const char *const path)
+{
+	size_t len = strlen (path);
+	bool trimmed = false;
+
+	while (len > 0  &&  (path [len - 1] == '/' || path [len - 1] == '\\'))
+	{
+		if (len == 1
+			|| (len == 2  &&  path [0] == '\\'  &&  path [1] == '\\')
+			|| (len == 3  &&  isalpha ((unsigned char) path [0])
+						   &&  path [1] == ':'
+						   &&  (path [2] == '/' || path [2] == '\\')))
+			break;
+		len--;
+		trimmed = true;
+	}
+
+	return trimmed? eStrndup (path, len): NULL;
+}
+#endif
+
