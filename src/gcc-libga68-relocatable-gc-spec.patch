   LIBGA68_GCFLAGS='-DLIBGA68_WITH_GC=1'
   LIBGA68_BOEHM_GC_INCLUDES=$BDW_GC_CFLAGS
   LIBGA68_BOEHM_GC_LIBS=$BDW_GC_LIBS
-  SPEC_LIBGA68_DEPS="$SPEC_LIBGA68_DEPS $BDW_GC_LIBS"
 fi
 
