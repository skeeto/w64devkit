libstdc++exp.a's default handle_contract_violation is marked weak so users
can supply their own. On PE-COFF __attribute__((weak)) does not act as a
fallback definition; it makes the symbol an alias for another (strong)
definition. With no such strong definition, the default does not resolve
and -fcontracts -lstdc++exp fails to link: https://gcc.gnu.org/PR124263
--- a/libstdc++-v3/src/experimental/contract26.cc
+++ b/libstdc++-v3/src/experimental/contract26.cc
@@ -132,5 +132,5 @@
 }
 }

-__attribute__ ((weak)) void
+void
 handle_contract_violation (const std::contracts::contract_violation &violation)
