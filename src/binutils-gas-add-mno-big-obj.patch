 #endif /* DEBUG_AARCH64 */
@@ -11382,12 +11378,6 @@ md_parse_option (int c, const char *arg)
       break;
 #endif
 
-#ifdef OBJ_COFF
-    case OPTION_MBIG_OBJ:
-      use_big_obj = true;
-      break;
-#endif
-
     case 'a':
