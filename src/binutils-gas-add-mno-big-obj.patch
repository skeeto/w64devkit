 gas/config/tc-aarch64.c           | 28 +++++++---------------------
 gas/config/tc-i386.c              | 20 +++++++++++---------
 gas/doc/c-aarch64.texi            |  5 ++++-
 gas/doc/c-i386.texi               |  7 +++++--
 gas/testsuite/gas/pe/no-big-obj.d |  6 ++++++
