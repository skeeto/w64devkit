@@ -11461,10 +11451,6 @@ md_show_usage (FILE * fp)
   -EL                     assemble code for a little-endian cpu\n"));
 #endif
 
-#ifdef OBJ_COFF
-  fprintf (fp, _("\
-  -mbig-obj               generate big object files\n"));
-#endif
