+	for i := uint32(0); i < numSections; i++ {
 		sh := new(SectionHeader32)
 		if err := binary.Read(sr, binary.LittleEndian, sh); err != nil {
 			return nil, err
diff --git a/src/debug/pe/pe.go b/src/debug/pe/pe.go
